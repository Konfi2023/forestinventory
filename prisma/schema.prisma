generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// --- IAM & MANDANTEN ---

model Plan {
  id             String         @id @default(uuid())
  name           String         @unique
  maxHectares    Float?         // null = unlimited
  maxUsers       Int?           // null = unlimited
  monthlyPriceId String?        // Stripe Price ID
  yearlyPriceId  String?        // Stripe Price ID
  monthlyPrice   Float?         // EUR, for display
  yearlyPrice    Float?         // EUR, for display
  isActive       Boolean        @default(true)
  displayOrder   Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organizations  Organization[]
}

model Organization {
  id                   String               @id @default(uuid())
  name                 String
  slug                 String               @unique
  defaultLanguage      String               @default("de")
  stripeCustomerId     String?
  subscriptionStatus   SubscriptionStatus   @default(FREE)
  onboardingComplete   Boolean              @default(false)
  stripeSubscriptionId String?              @unique
  stripePriceId        String?
  planId               String?
  plan                 Plan?                @relation(fields: [planId], references: [id])
  planInterval         String?              // "monthly" | "yearly"
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean              @default(false)
  customAreaLimit      Float?               // overrides plan.maxHectares if set
  customUserLimit      Int?                 // overrides plan.maxUsers if set
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  members              Membership[]
  roles                Role[]
  invites              Invite[]
  auditLogs            AuditLog[]
  forests              Forest[]
  // Globale Listen für CRM/Verkauf auf Org-Ebene
  timberSales          TimberSale[]
  legalName            String? // Offizieller Firmenname
  orgType              OrgType              @default(PRIVATE_OWNER)
  totalHectares        Float? // Betriebsgröße
  // Adresse & Rechnung
  billingEmail         String?
  vatId                String? // USt-IdNr.
  street               String?
  zip                  String?
  city                 String?
  country              String?              @default("Deutschland")
  // EUDR-Compliance
  eudrActivityType     String?              @default("DOMESTIC")
  eoriNumber           String?
  eudrStatements       DueDiligenceStatement[]

  // EUDR-API Verbindung (TRACES NT)
  eudrApiUrl           String?   // Endpunkt-URL des SOAP-Dienstes
  eudrApiUsername      String?   // TRACES NT Benutzername
  eudrApiPassword      String?   // TRACES NT Passwort
  eudrApiClientId      String?   @default("eudr-test")    // WebServiceClientId
  eudrApiEnvironment   String?   @default("ACCEPTANCE")   // ACCEPTANCE | PRODUCTION
  eudrApiEnabled       Boolean   @default(false)
  Event                Event[]
  forestOwners         ForestOwner[]
  serviceProviders     ServiceProvider[]
  rateCategories       RateCategory[]
  invoices             Invoice[]
  documents            OrgDocument[]
  // Bankverbindung & Rechnungseinstellungen
  iban                 String?
  bic                  String?
  bankName             String?
  isKleinunternehmer   Boolean              @default(false)
  defaultPaymentDays   Int                  @default(30)
  vatRates             VatRate[]
}

model ForestOwner {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  email          String?
  phone          String?
  street         String?
  zip            String?
  city           String?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  forests        Forest[]
  invoices       Invoice[]
  documents      OrgDocument[]
}

model VatRate {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  countryCode    String       // "DE", "AT", "CH", "FR"
  countryName    String       // "Deutschland", "Österreich", "Schweiz"
  rate           Decimal      @db.Decimal(5, 2)  // 19.00
  label          String       // "Normalsatz (19 %)"
  isDefault      Boolean      @default(false)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

model ServiceProvider {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  email          String?
  phone          String?
  street         String?
  zip            String?
  city           String?
  category       String?      // z.B. "Forstunternehmer", "Gutachter", "Sägewerk"
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model User {
  id                 String       @id @default(uuid())
  keycloakId         String       @unique
  email              String       @unique
  firstName          String?
  lastName           String?
  isSystemAdmin      Boolean      @default(false)
  companyName        String?
  vatId              String?
  street             String?
  zip                String?
  calendarToken String? @unique
  city               String?
  country            String?      @default("Deutschland")
  preferredLanguage  String       @default("de")
  onboardingComplete Boolean      @default(false)
  lastActiveOrgId    String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  memberships        Membership[]
  auditLogs          AuditLog[]
  accessibleForests  Forest[]     @relation("ForestAccess")
  

  // --- NEU: Zuweisungen & Tracking ---
  assignedTasks         Task[]         @relation("TaskAssignee")
  createdTasks          Task[]         @relation("TaskCreator")
  createdSchedules      TaskSchedule[] @relation("ScheduleCreator")
  createdEvents         Event[]
  timeEntries           TimeEntry[]
  taskComments          TaskComment[]
  watchedTasks          Task[]         @relation("TaskWatchers")
  receivedNotifications Notification[]    @relation("NotifReceiver")
  sentNotifications     Notification[]    @relation("NotifActor")
  TaskSchedule          TaskSchedule[]
  treeMeasurements      TreeMeasurement[] @relation("TreeMeasurements")
  inventoryPlots        InventoryPlot[]   @relation("InventoryPlots")
}

model Membership {
  id             String       @id @default(uuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  roleId         String
  role           Role         @relation(fields: [roleId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

model Role {
  id             String       @id @default(uuid())
  name           String
  description    String?
  permissions    String[]
  isSystemRole   Boolean      @default(false)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members        Membership[]
  invites        Invite[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([name, organizationId])
}

model Invite {
  id             String       @id @default(uuid())
  email          String
  token          String       @unique
  expiresAt      DateTime
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  roleId         String
  role           Role         @relation(fields: [roleId], references: [id])
  inviterId      String?
  status         String       @default("PENDING")
  createdAt      DateTime     @default(now())
}

model Event {
  id          String  @id @default(uuid())
  title       String
  description String?

  start  DateTime
  end    DateTime?
  allDay Boolean   @default(false)

  // Farbe für den Kalender (optional, sonst Standard)
  color String? @default("#10b981") // Standard Grün

  // Verknüpfungen
  forestId String? // Optional: Termin gehört zu einem Wald
  forest   Forest? @relation(fields: [forestId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id             String       @id @default(uuid())
  action         String
  entityId       String?
  entityType     String?
  metadata       Json?
  actorId        String
  user           User         @relation(fields: [actorId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
}

// --- DOMAIN: FORST (GIS & BESTÄNDE) ---

model Forest {
  id             String       @id @default(uuid())
  name           String
  location       String?
  description    String?
  geoJson        Json?        @db.JsonB
  areaHa         Float?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  color          String?      @default("#10b981")

  // GIS Layer
  paths            ForestPath[]
  biomassSnapshots ForestBiomassSnapshot[]
  polygonSnapshots ForestPolygonSnapshot[]
  weatherSnapshots ForestWeatherSnapshot[]
  s1Snapshots      ForestS1Snapshot[]
  pois        ForestPoi[]
  plantings   ForestPlanting[]
  maintenance ForestMaintenance[]
  calamities  ForestCalamity[]
  habitats    ForestHabitat[]
  hunting     ForestHunting[]
  skidTrails  SkidTrail[]
  compartments ForestCompartment[]
  inventoryPlots InventoryPlot[]

  // Operative Daten
  operations    Operation[]
  tasks         Task[] // Aufgaben hängen direkt am Wald
  taskSchedules TaskSchedule[]
  documents     Document[]
  images        Image[]
  treeRecords   TreeRecord[]
  animalRecords AnimalRecord[]
  grantedUsers  User[]         @relation("ForestAccess")
  Event         Event[]

  // Waldbesitzer
  ownerId       String?
  owner         ForestOwner?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)
}

// ... (Hier folgen die bestehenden GIS-Modelle unverändert) ...

model ForestHabitat {
  id               String  @id @default(uuid())
  geoJson          Json    @db.JsonB
  areaHa           Float?
  type             String?
  protectionStatus String?
  description      String?
  note             String?
  forestId         String
  forest           Forest  @relation(fields: [forestId], references: [id], onDelete: Cascade)
}

model ForestHunting {
  id       String  @id @default(uuid())
  geoJson  Json    @db.JsonB
  areaHa   Float?
  name     String?
  pachter  String?
  endsAt   String?
  note     String?
  forestId String
  forest   Forest  @relation(fields: [forestId], references: [id], onDelete: Cascade)
}

model ForestCalamity {
  id           String     @id @default(uuid())
  geoJson      Json       @db.JsonB
  areaHa       Float?
  cause        String?
  status       String?
  amount       Float?
  description  String?
  note         String?
  trackBiomass Boolean    @default(false)
  forestId     String
  forest       Forest     @relation(fields: [forestId], references: [id], onDelete: Cascade)
  operation    Operation? // verknüpfte Maßnahme (1:1, optional)
}

model ForestMaintenance {
  id          String     @id @default(uuid())
  geoJson     Json       @db.JsonB
  areaHa      Float?
  description String?
  activities  Json?      @db.JsonB
  note        String?
  operation   Operation?
  forestId    String
  forest      Forest     @relation(fields: [forestId], references: [id], onDelete: Cascade)
}

model ForestPlanting {
  id           String  @id @default(uuid())
  treeSpecies  String
  description  String?
  note         String?
  content      Json?   @db.JsonB
  geoJson      Json    @db.JsonB
  areaHa       Float?
  trackBiomass Boolean @default(false)
  forestId     String
  forest       Forest  @relation(fields: [forestId], references: [id], onDelete: Cascade)
}

model ForestPath {
  id       String  @id @default(uuid())
  type     String
  name     String?
  color    String?
  geoJson  Json    @db.JsonB
  lengthM  Float?
  note     String?
  forestId String
  forest   Forest  @relation(fields: [forestId], references: [id], onDelete: Cascade)
}

model ForestPoi {
  id       String             @id @default(uuid())
  type     String
  name     String?
  lat      Float
  lng      Float
  tasks    Task[]
  note     String?
  forestId String
  forest   Forest             @relation(fields: [forestId], references: [id], onDelete: Cascade)
  vehicle           ForestPoiVehicle?
  tree              ForestPoiTree?
  logPile           ForestPoiLogPile?
  operationLogPiles LogPile[]
  measurements      TreeMeasurement[]
}

model ForestPoiLogPile {
  id           String    @id @default(uuid())
  poiId        String    @unique
  poi          ForestPoi @relation(fields: [poiId], references: [id], onDelete: Cascade)
  volumeFm     Float?    // Festmeter (fm)
  logLength    Float?    // Stammlänge in Metern
  layerCount   Int?      // Anzahl der Lagen
  treeSpecies  String?   // Baumart
  woodType     String?   @default("LOG") // LOG | INDUSTRIAL | ENERGY | PULP
  qualityClass String?   // A, B, C, D, IL, E
  imageKey     String?   // S3-Key / lokaler Pfad des Fotos
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model ForestPoiVehicle {
  id             String      @id @default(uuid())
  poiId          String      @unique
  poi            ForestPoi   @relation(fields: [poiId], references: [id], onDelete: Cascade)
  vehicleType    VehicleType @default(OTHER)
  serialNumber   String?
  yearBuilt      Int?
  lastInspection DateTime?
  nextInspection DateTime?
  imageKey       String?
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([nextInspection])
}

model ForestPoiTree {
  id         String     @id @default(uuid())
  poiId      String     @unique
  poi        ForestPoi  @relation(fields: [poiId], references: [id], onDelete: Cascade)
  species    String?
  age        Int?
  diameter   Float?
  height     Float?
  co2Storage Float?
  health        TreeHealth    @default(HEALTHY)
  damageType    String?       // Schadursache (Freitext: Borkenkäfer, Trocken, Pilz, …)
  damageSeverity Int?         // Schadausmaß 0–100 %
  crownCondition Int?         // Kronenanteil vital 0–100 %

  // Standort-Eigenschaften (selten ändernd)
  soilCondition SoilCondition?
  soilMoisture  SoilMoisture?
  exposition    Exposition?
  slopeClass    SlopeClass?
  slopePosition SlopePosition?
  standType     StandType?
  stockingDegree StockingDegree?

  imageKey       String?  // Stammfoto
  crownImageKey  String?  // Kronenfoto

  // Abteilung (Forsteinrichtung)
  compartmentId String?
  compartment   ForestCompartment? @relation(fields: [compartmentId], references: [id], onDelete: SetNull)

  // Probekreis (Plot-Stichprobe)
  plotId String?
  plot   InventoryPlot? @relation(fields: [plotId], references: [id], onDelete: SetNull)

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([species])
  @@index([plotId])
}

model ForestCompartment {
  id           String  @id @default(uuid())
  geoJson      Json    @db.JsonB
  areaHa       Float?
  name         String?
  number       String?           // Abteilungsnummer
  color        String? @default("#3b82f6")
  note         String?
  trackBiomass Boolean @default(false)

  // Standort
  soilType         String?       // Bodentyp
  waterBalance     String?       // Wasserhaushalt
  nutrientLevel    String?       // Nährstoffstufe
  exposition       String?       // N/NO/O/SO/S/SW/W/NW/eben
  slopeClass       String?       // eben/schwach/mittel/steil/sehr steil
  protectionStatus String?       // Schutzstatus
  restrictions     String?       // Restriktionen/Auflagen

  // Bestand
  standAge         Int?          // Bestandesalter (Jahre)
  developmentStage String?       // Blöße/Verjüngung/Dickung/Stangenholz/…
  mainSpecies      Json?         // [{species: string, percent: number}]
  sideSpecies      Json?         // [{species: string, percent: number}]
  mixingForm       String?       // rein/horst/trupp/gruppen/einzeln/misch
  structure        String?       // einschichtig/mehrschichtig/plenterartig

  // Kennzahlen (manuell; auto-werte kommen von TreePOIs)
  volumePerHa      Float?        // Vorrat m³/ha
  incrementPerHa   Float?        // Zuwachs m³/ha/a
  stockingDegree   Float?        // Bestockungsgrad 0–1
  deadwoodPerHa    Float?        // Totholz m³/ha
  yieldClass       Float?        // Bonität (Ertragsklasse)
  siteProductivity String?       // Wuchsleistung (gering/mittel/hoch/sehr hoch)

  // Verjüngung
  rejuvenation     Json?         // [{species: string, heightCm: number, density: string}]

  // Zustand
  vitalityNote     String?       // Vitalitätsbeschreibung
  damageNote       String?       // Schadensbeschreibung
  stabilityNote    String?       // Stabilitätsbeschreibung

  // Bewirtschaftung
  lastMeasureDate  String?       // Datum letzte Nutzung/Maßnahme
  lastMeasureType  String?       // Art der Maßnahme
  maintenanceStatus String?      // Pflegezustand
  accessibility    String?       // Befahrbarkeit

  forestId     String
  forest       Forest  @relation(fields: [forestId], references: [id], onDelete: Cascade)
  trees        ForestPoiTree[]
  inventoryPlots InventoryPlot[]
}

// Probekreis für Plot-Stichprobeninventur
model InventoryPlot {
  id            String   @id @default(uuid())
  name          String?  // z. B. "Plot 1" oder "P-A3-01"
  lat           Float    // Mittelpunkt des Probekreises
  lng           Float
  radiusM       Float    @default(10.0) // Probekreisradius in Metern
  measuredAt    DateTime @default(now())
  measuredById  String?
  measuredBy    User?    @relation("InventoryPlots", fields: [measuredById], references: [id], onDelete: SetNull)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  forestId      String
  forest        Forest             @relation(fields: [forestId], references: [id], onDelete: Cascade)
  compartmentId String?
  compartment   ForestCompartment? @relation(fields: [compartmentId], references: [id], onDelete: SetNull)

  trees         ForestPoiTree[]

  @@index([forestId])
  @@index([compartmentId])
}

// Historische Messwerte pro Baum (Phase 2: Zeitreihe)
model TreeMeasurement {
  id           String     @id @default(uuid())
  poiId        String
  poi          ForestPoi  @relation(fields: [poiId], references: [id], onDelete: Cascade)
  measuredAt   DateTime   @default(now())
  measuredById String?
  measuredBy   User?      @relation("TreeMeasurements", fields: [measuredById], references: [id], onDelete: SetNull)

  // Dendrologische Messwerte
  diameter      Float?
  height        Float?
  age           Int?
  co2Storage    Float?

  // Vitalität zum Messzeitpunkt
  health         TreeHealth @default(HEALTHY)
  damageType     String?
  damageSeverity Int?
  crownCondition Int?

  // Bodenfeuchtigkeit kann sich ändern
  soilMoisture SoilMoisture?

  notes    String?
  imageKey String?

  createdAt DateTime @default(now())

  @@index([poiId, measuredAt])
}

// Biomasse-Zeitreihe: periodisch gespeicherte NDVI-Werte pro Waldfläche
// Vorbereitung für Biomasse- und Abholzungs-Tracking (Sidebar "Biomasse")
// Befüllung via: Sentinel Hub Statistical API (POST /api/biomass/snapshot)
model ForestBiomassSnapshot {
  id         String   @id @default(uuid())
  forestId   String
  forest     Forest   @relation(fields: [forestId], references: [id], onDelete: Cascade)
  date       DateTime // Datum des Sentinel-2 Referenzbildes
  meanNdvi   Float?   // Mittlerer NDVI (-1 bis 1), Proxy für Biomasseentwicklung
  minNdvi    Float?
  maxNdvi    Float?
  cloudPct   Float?   // Wolkenbedeckung in % (Qualitätsindikator)
  source     String   @default("SENTINEL2_L2A")
  createdAt  DateTime @default(now())

  @@index([forestId, date])
}

// Tägliche Wetterdaten pro Wald (Open-Meteo, kein API-Key nötig)
model ForestWeatherSnapshot {
  id              String   @id @default(uuid())
  forestId        String
  forest          Forest   @relation(fields: [forestId], references: [id], onDelete: Cascade)
  date            DateTime // Tag (00:00:00 UTC)

  // Temperatur
  maxTempC        Float?   // Tagesmaximum °C
  minTempC        Float?   // Tagesminimum °C
  avgTempC        Float?   // (max+min)/2

  // Niederschlag & Verdunstung
  precipMm        Float?   // Tagesniederschlag mm
  et0Mm           Float?   // FAO-56 Referenz-Evapotranspiration mm
  waterBalanceMm  Float?   // precip - et0 (negativ = Trockenheitsdefizit)

  // Wind & Sonne
  windMaxKmh      Float?   // Max. Windböen km/h
  windAvgKmh      Float?   // Tagesmittel Windgeschwindigkeit km/h
  windDirDeg      Float?   // Mittlere Windrichtung (° meteorologisch, 0=N, 90=O, 180=S, 270=W)
  isStorm         Boolean  @default(false) // windMaxKmh >= 62 (Bft 8 Sturm)
  sunshineDurationH Float? // Sonnenstundendauer h

  // Bodenfeuchte (0–7 cm Tiefe, m³/m³)
  soilMoisture    Float?

  // Abgeleitete Indikatoren
  isFrost         Boolean  @default(false) // minTemp < 0
  isHeatStress    Boolean  @default(false) // maxTemp > 30
  barkBeetleRisk  Boolean  @default(false) // avgTemp ≥ 16.5 AND precipMm < 2

  source          String   @default("OPEN_METEO")
  createdAt       DateTime @default(now())

  @@unique([forestId, date])
  @@index([forestId, date])
}

// Tägliche Sentinel-1 SAR Rückstreuungs-Snapshots pro Wald
model ForestS1Snapshot {
  id          String   @id @default(uuid())
  forestId    String
  forest      Forest   @relation(fields: [forestId], references: [id], onDelete: Cascade)
  date        DateTime // Aufnahmedatum (00:00:00 UTC)

  // VH Polarisation (Volumen-Streuung, sensitiv für Biomasse)
  vhMean      Float?   // Linearer Mittelwert
  vhStd       Float?   // Standardabweichung
  vhMeanDb    Float?   // In dB (10*log10)

  // VV Polarisation (Oberflächen-Streuung)
  vvMean      Float?
  vvStd       Float?
  vvMeanDb    Float?

  // Abgeleitete Indikatoren
  ratio       Float?   // VH/VV (sensitiv für Vegetationsstruktur)
  baselineDb  Float?   // Rollendes 6-Snapshot Median VH (dB) zum Zeitpunkt der Aufnahme
  changeDb    Float?   // Abweichung vom Baseline (baselineDb - vhMeanDb)
  isAnomaly   Boolean  @default(false) // |changeDb| > 3 dB

  sceneCount  Int      @default(1)     // Anzahl S1-Szenen im Zeitfenster
  source      String   @default("SENTINEL1_GRD")
  createdAt   DateTime @default(now())

  @@unique([forestId, date])
  @@index([forestId, date])
  @@index([isAnomaly])
}

// Sentinel-1 SAR Snapshots für einzelne Polygon-Flächen (Pflanzungen, Kalamitäten)
model ForestPolygonSnapshot {
  id          String   @id @default(uuid())
  polygonId   String   // ID der ForestPlanting oder ForestCalamity
  polygonType String   // 'PLANTING' | 'CALAMITY'
  forestId    String
  forest      Forest   @relation(fields: [forestId], references: [id], onDelete: Cascade)
  date        DateTime

  vhMeanDb    Float?
  vvMeanDb    Float?
  changeDb    Float?
  baselineDb  Float?
  isAnomaly   Boolean  @default(false)
  sceneCount  Int      @default(1)
  source      String   @default("SENTINEL1_GRD")
  createdAt   DateTime @default(now())

  @@unique([polygonId, date])
  @@index([polygonId, date])
  @@index([polygonType, isAnomaly])
}

model SkidTrail {
  id       String  @id @default(uuid())
  name     String?
  geoJson  Json    @db.JsonB
  lengthM  Float?
  forestId String
  forest   Forest  @relation(fields: [forestId], references: [id], onDelete: Cascade)
}

// --- DOMAIN: OPERATIONS & PROZESSE ---

// Operation dient jetzt als "Container" oder "Epic" für größere Maßnahmen (z.B. "Jahresplanung 2026")
model Operation {
  id          String          @id @default(uuid())
  title       String
  year        Int
  status      OperationStatus @default(PLANNED) // Geändert zu Enum
  description String?
  type        OperationType   @default(HARVEST)

  forestId String
  forest   Forest @relation(fields: [forestId], references: [id], onDelete: Cascade)

  // Optionale Verknüpfung zu einem GIS-Objekt
  maintenanceId String?            @unique
  maintenance   ForestMaintenance? @relation(fields: [maintenanceId], references: [id])

  calamityId    String?            @unique
  calamity      ForestCalamity?    @relation(fields: [calamityId], references: [id], onDelete: SetNull)

  // Relationen
  tasks       Task[] // Eine Operation hat viele Aufgaben
  harvests    Harvest[]
  logPiles    LogPile[]
  plantings   Planting[]
  costs       Cost[]
  shareTokens OperationToken[]
  timeEntries TimeEntry[]
  // Bilanzierung
  timberSales TimberSale[] // Verkaufskontrakte zu dieser Maßnahme

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OperationToken {
  id          String    @id @default(uuid())
  token       String    @unique
  expiresAt   DateTime
  operationId String
  operation   Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

// --- NEU: TASK MANAGEMENT (JIRA-STYLE) ---

model Task {
  id            String       @id @default(uuid())
  title         String
  description   String?
  status        TaskStatus   @default(OPEN)
  priority      TaskPriority @default(MEDIUM)
  estimatedTime Int?
  dueDate       DateTime?
  scheduledDate    DateTime?    // START: Wann mache ich es?
  scheduledEndDate DateTime? 
  images        Image[]
  documents     Document[]
  poiId         String?
  poi           ForestPoi? @relation(fields: [poiId], references: [id], onDelete: SetNull)

  // Polygon-Verknüpfung (optional): Kultur, Kalamität, Jagd oder Weg
  linkedPolygonId   String?
  linkedPolygonType String? // 'PLANTING' | 'CALAMITY' | 'HUNTING' | 'PATH'

  // Georeferenzierung (Optional): Wo genau ist die Aufgabe?
  lat Float?
  lng Float?

  // Verknüpfung
  forestId String
  forest   Forest @relation(fields: [forestId], references: [id], onDelete: Cascade)

  operationId String? // Optional: Gehört zu einer großen Maßnahme
  operation   Operation? @relation(fields: [operationId], references: [id])

  // Zuweisung
  assigneeId    String?
  assignee      User?          @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creatorId     String
  creator       User           @relation("TaskCreator", fields: [creatorId], references: [id])
  watchers      User[]         @relation("TaskWatchers")
  notifications Notification[]

  // Sub-Ressourcen
  timeEntries TimeEntry[]
  comments    TaskComment[]

  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  scheduleId String?
  schedule   TaskSchedule? @relation(fields: [scheduleId], references: [id])
}

model Notification {
  id      String           @id @default(uuid())
  type    NotificationType
  title   String
  message String?
  isRead  Boolean          @default(false)

  // Wer bekommt es?
  userId String
  user   User   @relation("NotifReceiver", fields: [userId], references: [id], onDelete: Cascade)

  // Wer hat es ausgelöst?
  actorId String?
  actor   User?   @relation("NotifActor", fields: [actorId], references: [id])

  // Kontext
  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model TaskSchedule {
  id String @id @default(uuid())

  // Was soll erstellt werden? (Template Daten)
  title       String
  description String?
  priority    TaskPriority @default(MEDIUM)
  forestId    String
  forest      Forest       @relation(fields: [forestId], references: [id], onDelete: Cascade)
  assigneeId  String?
  assignee    User?        @relation(fields: [assigneeId], references: [id])
  creatorId   String
  creator     User         @relation("ScheduleCreator", fields: [creatorId], references: [id])

  // Die Wiederholungs-Regel
  interval Int // z.B. 2
  unit     RecurrenceUnit // z.B. WEEKS (Alle 2 Wochen)

  startDate DateTime // Wann geht es los?
  endDate   DateTime? // Wann hört es auf? (Optional)

  lastGeneratedAt DateTime? // Wann wurde die letzte Aufgabe generiert?
  nextRunAt       DateTime // Wann ist die nächste fällig?

  // Relationen
  tasks  Task[] // Alle Aufgaben, die hieraus entstanden sind
  active Boolean @default(true) // Serie pausieren

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskComment {
  id        String   @id @default(uuid())
  content   String
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

// --- NEU: ZEITERFASSUNG & RESSOURCEN ---

model TimeEntry {
  id              String    @id @default(uuid())
  description     String? // Was wurde gemacht?
  startTime       DateTime
  endTime         DateTime? // Null wenn Timer noch läuft
  durationMinutes Int? // Berechnet oder manuell eingetragen

  category TimeCategory @default(MANUAL_WORK)

  // Stundensatz-Kategorie
  rateCategoryId     String?
  rateCategory       RateCategory? @relation(fields: [rateCategoryId], references: [id])
  hourlyRateOverride Decimal?      @db.Decimal(10, 2)

  // Abrechnung
  invoiceId String?
  invoice   Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  billedAt  DateTime?

  // Verknüpfung (Entweder Task oder Operation oder beides)
  taskId      String?
  task        Task?      @relation(fields: [taskId], references: [id])
  operationId String?
  operation   Operation? @relation(fields: [operationId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model RateCategory {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  key            String?      // Mapping zu TimeCategory enum (z.B. "MANUAL_WORK")
  hourlyRate     Decimal      @default(0) @db.Decimal(10, 2)
  color          String?      @default("#94a3b8")
  sortOrder      Int          @default(0)
  isBuiltIn      Boolean      @default(false) // Standard-Kategorien sind geschützt
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  timeEntries    TimeEntry[]
}

// --- DOMAIN: HOLZ & BILANZIERUNG ---

// Harvest ist die "Planung" oder "Meldung" des Einschlags
model Harvest {
  id          String      @id @default(uuid())
  date        DateTime    @default(now())
  harvestType HarvestType
  woodType    WoodType
  treeSpecies String
  quality     String?

  amount Float // Menge (fm)
  unit   String // fm, rm, srm

  revenue Decimal? @db.Decimal(10, 2) // Geplanter Erlös
  isSold  Boolean  @default(false)

  note        String?
  operationId String
  operation   Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)
}

// LogPile ist das physische Polter im Wald (Inventur)
model LogPile {
  id     String       @id @default(uuid())
  name   String? // z.B. "Polter A1"
  status PolterStatus @default(PILED)

  // Geo
  lat Float?
  lng Float?

  // Optional: verknüpft mit einem ForestPoi (LOG_PILE) auf der Karte
  forestPoiId String?
  forestPoi   ForestPoi? @relation(fields: [forestPoiId], references: [id], onDelete: SetNull)

  // Mengen (Waldmaß)
  estimatedAmount Float? // Geschätzt vom Förster
  measuredAmount  Float? // Exakt vermessen (Sektionsraummaß/Klammer)
  logLength       Float? // z.B. 5.10m
  unit            String? // fm o.R.

  // Qualität
  woodType     WoodType?
  treeSpecies  String?
  qualityClass String? // B, C, D, IL

  imageUrl String?
  note     String?

  operationId String
  operation   Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)

  // --- NEU: Verkauf ---
  timberSaleId String? // Gehört zu diesem Verkaufskontrakt
  timberSale   TimberSale? @relation(fields: [timberSaleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- NEU: VERKAUF & LOGISTIK ---

model TimberSale {
  id             String           @id @default(uuid())
  contractNumber String? // Vertragsnummer beim Sägewerk
  buyerName      String // Käufer (Sägewerk/Händler)
  status         TimberSaleStatus @default(DRAFT)
  date           DateTime         @default(now())

  // Preise
  pricePerUnit Decimal? @db.Decimal(10, 2)
  currency     String   @default("EUR")

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  operationId String? // Optional: Wenn Verkauf nur zu einer Maßnahme gehört
  operation   Operation? @relation(fields: [operationId], references: [id])

  // EUDR-Compliance (Verordnung EU 2023/1115)
  eudrReference String? // DDS-Referenznummer — gilt für alle Abfuhrscheine dieses Verkaufs

  // Inhalte
  logPiles         LogPile[] // Welche Polter gehören dazu?
  transportTickets TransportTicket[] // Abfuhrscheine (Lieferscheine)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TransportTicket {
  id           String   @id @default(uuid())
  ticketNumber String   // Lieferschein-Nr.
  plateNumber  String?  // LKW Kennzeichen
  driverName   String?  // Fahrername
  carrierName  String?  // Spediteur / Frachtführer
  pickupDate   DateTime // Abfuhrdatum

  // Waldmaß (Forstmaß) — vom Förster gemessene Menge
  forestAmount Float?
  forestUnit   String?  @default("fm")

  // Werksmaß (Werkseingang) — maßgeblich für Abrechnung
  factoryAmount Float
  factoryUnit   String  @default("fm")

  // EUDR-Pflichtfeld (Verordnung EU 2023/1115)
  eudrReference String? // DDS-Referenznummer

  note      String?  // interne Bemerkungen

  timberSaleId String
  timberSale   TimberSale @relation(fields: [timberSaleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- ANDERE MODELLE (Unverändert) ---

model Planting {
  id             String    @id @default(uuid())
  date           DateTime  @default(now())
  treeSpecies    String
  scientificName String?
  provenance     String?
  sortiment      String?
  plantType      String?
  count          Int
  geoJson        Json?     @db.JsonB
  areaHa         Float?
  note           String?
  operationId    String
  operation      Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)
}

model Cost {
  id          String    @id @default(uuid())
  title       String
  amount      Decimal   @db.Decimal(10, 2)
  date        DateTime  @default(now())
  category    String
  operationId String
  operation   Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)
}

model Document {
  id        String   @id @default(uuid())
  name      String
  s3Key     String
  url       String
  type      String
  category  String
  date      DateTime @default(now())
  note      String?
  forestId  String?
  forest    Forest?  @relation(fields: [forestId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Image {
  id        String   @id @default(uuid())
  name      String
  s3Key     String
  url       String
  lat       Float?
  lng       Float?
  forestId  String?
  forest    Forest?  @relation(fields: [forestId], references: [id], onDelete: Cascade)
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model TreeRecord {
  id         String   @id @default(uuid())
  species    String
  count      Int?
  volume     Float?
  health     String?
  recordedAt DateTime @default(now())
  forestId   String
  forest     Forest   @relation(fields: [forestId], references: [id], onDelete: Cascade)
}

model AnimalRecord {
  id         String           @id @default(uuid())
  species    String
  count      Int
  type       AnimalRecordType @default(SIGHTING)
  recordedAt DateTime         @default(now())
  forestId   String
  forest     Forest           @relation(fields: [forestId], references: [id], onDelete: Cascade)
}

model Invoice {
  id             String        @id @default(uuid())
  invoiceNumber  String
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  forestOwnerId  String
  forestOwner    ForestOwner   @relation(fields: [forestOwnerId], references: [id])
  status         InvoiceStatus @default(DRAFT)
  totalAmount    Decimal       @db.Decimal(10, 2)
  currency       String        @default("EUR")
  note           String?
  periodFrom     DateTime?
  periodTo       DateTime?
  issuedAt       DateTime?
  sentAt         DateTime?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  timeEntries    TimeEntry[]
  document       OrgDocument?

  @@index([organizationId, status])
  @@index([forestOwnerId])
}

model OrgDocument {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  forestOwnerId  String?
  forestOwner    ForestOwner? @relation(fields: [forestOwnerId], references: [id])
  invoiceId      String?      @unique
  invoice        Invoice?     @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  type           DocumentType
  title          String
  storageKey     String       // S3 key
  fileSize       Int?
  forestIds      String[]     // Alle Wälder, auf die sich das Dokument bezieht
  periodFrom     DateTime?
  periodTo       DateTime?
  sentAt         DateTime?
  sentTo         String?      // E-Mail-Adresse des Empfängers
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([forestOwnerId])
}

// --- ENUMS ---

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
}

enum DocumentType {
  INVOICE
  ACTIVITY_REPORT
  COMBINED   // Rechnung + Tätigkeitsnachweis zusammen
  OTHER
}

enum OperationType {
  HARVEST
  PLANTING
  MAINTENANCE
  PLANNING // Neu
  MONITORING // Neu
}

enum OperationStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  ON_HOLD
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  DONE
  REVIEW
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum RecurrenceUnit {
  DAYS
  WEEKS
  MONTHS
  YEARS
}

enum TimeCategory {
  MANUAL_WORK // Handarbeit (Pflanzen, Zaunbau)
  MACHINE_WORK // Maschinenzeit (Harvester, Mulcher)
  PLANNING // Büro/Planung
  TRAVEL // Anfahrt
  INSPECTION // Begehung/Kontrolle
}

enum HarvestType {
  REGULAR
  CALAMITY
  SAFETY
  THINNING // Durchforstung (Neu)
}

enum WoodType {
  LOG // Stammholz
  INDUSTRIAL // Industrieholz
  ENERGY // Energieholz/Hackschnitzel
  PULP // Papierholz
}

enum PolterStatus {
  PILED // Liegt im Wald (Gepoltert)
  MEASURED // Vermessen (Aufgenommen)
  SOLD // Verkauft (Vertraglich gebunden)
  COLLECTED // Abgefahren (Lieferschein vorhanden)
}

enum TimberSaleStatus {
  DRAFT
  NEGOTIATION
  CONTRACT_SIGNED
  COMPLETED
  CANCELLED
}

enum AnimalRecordType {
  SIGHTING
  HUNTING
  INVENTORY
  DAMAGE // Wildschaden (Neu)
}

enum NotificationType {
  ASSIGNED
  STATUS_CHANGE
  COMMENT
  MENTION
  DUE_SOON
}

enum OrgType {
  PRIVATE_OWNER // Privatwaldbesitzer
  FORESTRY_COMPANY // Forstbetrieb / GmbH
  SERVICE_PROVIDER // Lohnunternehmer / Dienstleister
  ASSOCIATION // FBch / WBV (Zusammenschluss)
  PUBLIC // Kommune / Staat
}

enum VehicleType {
  EXCAVATOR   // Bagger
  HARVESTER   // Harvester / Vollernter
  FORWARDER   // Forwarder / Rückefahrzeug
  TRACTOR     // Traktor / Schlepper
  SKIDDER     // Seilschlepper / Rückezug
  CRANE_TRUCK // LKW mit Ladekran
  MULCHER     // Mulcher
  CHAINSAW    // Motorsäge
  TRAILER     // Anhänger
  OTHER       // Sonstiges
}

enum TreeHealth {
  HEALTHY             // Gesund
  DAMAGED             // Geschädigt
  DEAD                // Abgestorben
  MARKED_FOR_FELLING  // Zum Fällen markiert
}

enum SoilCondition {
  SANDY  // Sandig
  LOAMY  // Lehmig
  CLAY   // Tonig
  HUMUS  // Humos
  ROCKY  // Steinig / Skelettreich
  MIXED  // Gemischt
}

enum SoilMoisture {
  DRY         // Trocken
  FRESH       // Frisch
  MOIST       // Feucht
  WET         // Nass
  WATERLOGGED // Staunass
}

enum Exposition {
  N     // Nord
  NE    // Nordost
  E     // Ost
  SE    // Südost
  S     // Süd
  SW    // Südwest
  W     // West
  NW    // Nordwest
  FLAT  // Eben (keine Exposition)
}

enum SlopeClass {
  FLAT       // Flach (<5°)
  MODERATE   // Mäßig (5–15°)
  STEEP      // Steil (15–30°)
  VERY_STEEP // Sehr steil (>30°)
}

enum SlopePosition {
  SUMMIT      // Kuppe
  UPPER_SLOPE // Oberhang
  MID_SLOPE   // Mittelhang
  LOWER_SLOPE // Unterhang
  VALLEY      // Talboden
}

enum StandType {
  PURE_CONIFER    // Reiner Nadelbestand
  PURE_DECIDUOUS  // Reiner Laubbestand
  MIXED           // Mischbestand
  EDGE            // Waldrand
  CLEARCUT        // Freifläche / Schlagfläche
  YOUNG_GROWTH    // Jungwuchs / Verjüngung
}

enum StockingDegree {
  OPEN       // Locker
  SPARSE     // Licht
  MEDIUM     // Mittel
  DENSE      // Dicht
  VERY_DENSE // Sehr dicht
}

enum SubscriptionStatus {
  FREE
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

// --- ALARM-QUITTIERUNGEN ---

model AlertAcknowledgement {
  id          String   @id @default(uuid())
  alertId     String   // ID des S1/Weather-Snapshots
  alertType   String   // 'SAR_ANOMALY' | 'STORM'
  forestId    String
  forestName  String
  userId      String
  userEmail   String
  isTest      Boolean  @default(false)
  dismissedAt DateTime @default(now())

  @@unique([alertId, userId])
  @@index([dismissedAt])
  @@index([userId])
}

// --- SYSTEM HEALTH MONITORING ---

model SystemHealthCheck {
  id            String   @id @default(uuid())
  runAt         DateTime @default(now())

  // Gesamtstatus: 'OK' | 'WARN' | 'ERROR'
  overall       String

  // Einzelne Service-Status
  dbOk          Boolean  @default(false)
  openMeteoOk   Boolean  @default(false)
  sentinelOk    Boolean  @default(false)
  s3Ok          Boolean  @default(false)

  // Detaillierter Bericht (Latenzen, Fehlermeldungen, Datenfreshness)
  report        Json

  // Test-Alarm IDs (zur Verifikation im Monitoring-Dashboard)
  testAlertS1Id String?
  testAlertWxId String?

  @@index([runAt])
}

// --- EUDR-COMPLIANCE ---

model DueDiligenceStatement {
  id              String    @id @default(uuid())
  orgId           String
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  status          String    @default("DRAFT") // DRAFT | SUBMITTED | ACCEPTED | RETRACTED
  activityType    String    // DOMESTIC | IMPORT | EXPORT
  internalNote    String?

  // Von der EUDR-API zurück
  referenceNumber    String?
  verificationNumber String?   // Zweite Nummer aus der API-Antwort
  tracesNtId         String?   // Interne ID im TRACES NT System
  submittedAt        DateTime?

  // Erntedaten (Pflichtfeld für API-Einreichung)
  harvestStartDate DateTime?
  harvestEndDate   DateTime?

  // Compliance-Snapshot (eingefroren beim Einreichen)
  snapshotGeoJson Json?
  snapshotRisk    Json?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  products        EudrProduct[]
  documents       EudrDocument[]

  @@index([orgId, status])
}

model EudrProduct {
  id               String   @id @default(uuid())
  statementId      String
  statement        DueDiligenceStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)

  hsCode           String   // 4403 | 4407 | 4408 | 4412 | 4418
  description      String?
  scientificName   String?  // Picea abies
  treeSpecies      String?  // Verweis auf internen Species-Key (SPRUCE etc.)

  quantityM3       Float?
  quantityKg       Float?

  countryOfHarvest String   @default("DE")

  // Verknüpfte Flächen aus dem eigenen System
  forestId         String?
  polygonIds       String[] @default([])
}

model EudrDocument {
  id          String   @id @default(uuid())
  statementId String
  statement   DueDiligenceStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)

  docType     String   // CERTIFICATE | OWNERSHIP | LEGAL_BASIS | OTHER
  filename    String
  s3Key       String
  uploadedAt  DateTime @default(now())
}
