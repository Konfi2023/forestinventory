<file path="components/map/stores/useMapStores.ts">
import { create } from 'zustand';
import { devtools } from 'zustand/middleware';

// Definiert die erlaubten Layer-IDs (muss mit LayerRegistry übereinstimmen)
export type LayerId = 
  | 'FOREST_BOUNDARY' 
  | 'SECTIONS'        // Abteilungen/Bestände
  | 'TASKS'           // Offene Aufgaben (Pins)
  | 'INFRASTRUCTURE'  // Wege, Hochsitze
  | 'ACTIVITY_PLAN'   // Geplante Maßnahmen (Polygone)
  | 'CADASTRAL';      // Flurstücke (WMS)

// Definiert, was angeklickt werden kann
export type FeatureType = 'FOREST' | 'TASK' | 'POI' | 'POLYGON' | 'PATH';

// WICHTIG: Exportiere das Interface, damit wir es in Komponenten typisieren können!
export interface MapState {
  // 1. View State
  center: [number, number];
  zoom: number;
  isReady: boolean;

  // 2. Layer Control
  activeLayers: LayerId[];
  
  // 3. Selektion (Verknüpfung zu Kanban/Sidebar)
  selectedFeatureId: string | null;
  selectedFeatureType: FeatureType | null;
  
  // 4. Hover State (für Performance-optimiertes Highlighting)
  hoveredFeatureId: string | null;

  // 5. Interaktions-Modus (Für den Editor)
  interactionMode: 'VIEW' | 'DRAW_FOREST';

  // Actions
  setMapReady: (ready: boolean) => void;
  toggleLayer: (layer: LayerId) => void;
  setLayerVisibility: (layer: LayerId, visible: boolean) => void;
  selectFeature: (id: string | null, type: FeatureType | null) => void;
  setHoveredFeature: (id: string | null) => void;
  setInteractionMode: (mode: 'VIEW' | 'DRAW_FOREST') => void;
  
  // Map Movement (wird beim Mounten der Map überschrieben)
  flyTo: (coords: [number, number], zoom?: number) => void;
}

export const useMapStore = create<MapState>()(
  devtools((set) => ({
    // Initiale Werte
    center: [51.1657, 10.4515], // Default Zentrum (Deutschland)
    zoom: 6,
    isReady: false,
    
    // Standardmäßig aktive Layer
    activeLayers: ['FOREST_BOUNDARY', 'SECTIONS', 'TASKS', 'INFRASTRUCTURE'],
    
    selectedFeatureId: null,
    selectedFeatureType: null,
    hoveredFeatureId: null,
    interactionMode: 'VIEW',

    // Implementation der Actions
    setMapReady: (ready) => set({ isReady: ready }),
    
    toggleLayer: (layer) => set((state) => {
      const isActive = state.activeLayers.includes(layer);
      return {
        activeLayers: isActive 
          ? state.activeLayers.filter(l => l !== layer) // Entfernen
          : [...state.activeLayers, layer]              // Hinzufügen
      };
    }),

    setLayerVisibility: (layer, visible) => set((state) => {
      if (visible && !state.activeLayers.includes(layer)) {
        return { activeLayers: [...state.activeLayers, layer] };
      }
      if (!visible && state.activeLayers.includes(layer)) {
        return { activeLayers: state.activeLayers.filter(l => l !== layer) };
      }
      return {};
    }),

    selectFeature: (id, type) => set({ 
      selectedFeatureId: id, 
      selectedFeatureType: type 
    }),
    
    setHoveredFeature: (id) => set({ hoveredFeatureId: id }),

    setInteractionMode: (mode) => set({ interactionMode: mode }),
    
    // Platzhalter-Funktion. Diese wird im MapViewer.tsx überschrieben,
    // sobald die Leaflet-Instanz verfügbar ist.
    flyTo: (coords, zoom) => console.warn("Map not initialized yet", coords, zoom), 
  }))
);
</file>

<file path="components/map/viewer/GeoDataHandler.tsx">
'use client';

import { useMapStore, MapState } from '../stores/useMapStores'; 
import { LAYER_REGISTRY } from '../registry/LayerRegistry';
import { Polygon, Marker, Popup, Polyline, Tooltip } from 'react-leaflet';
import { geoJSONToLeaflet } from '@/lib/map-helpers';
import L from 'leaflet';

// Props Interface definiert, was wir von der Server Component erwarten
interface MapDataProps {
  data: {
    forests: any[]; // Prisma Forest Type
    tasks: any[];   // Prisma Task Type
  };
}

export function GeoDataHandler({ data }: MapDataProps) {
  // 1. Store Hooks (Selektoren für Performance)
  const activeLayers = useMapStore((s: MapState) => s.activeLayers);
  const selectFeature = useMapStore((s: MapState) => s.selectFeature);
  const selectedId = useMapStore((s: MapState) => s.selectedFeatureId);
  const hoveredId = useMapStore((s: MapState) => s.hoveredFeatureId);
  const setHovered = useMapStore((s: MapState) => s.setHoveredFeature);

  // 2. Visibility Checks
  const showForests = activeLayers.includes('FOREST_BOUNDARY');
  const showInfrastructure = activeLayers.includes('INFRASTRUCTURE');
  const showTasks = activeLayers.includes('TASKS');

  // 3. Styles definieren
  const getForestStyle = (id: string) => {
    const isSelected = selectedId === id;
    const isHovered = hoveredId === id;
    const baseColor = LAYER_REGISTRY.FOREST_BOUNDARY.color;

    return {
      color: isSelected ? '#ffffff' : baseColor, // Weiß bei Selektion
      weight: isSelected || isHovered ? 3 : 2,
      fillColor: baseColor,
      fillOpacity: isSelected ? 0.3 : 0.1,
      dashArray: '5, 5'
    };
  };

  return (
    <>
      {/* --- LAYER: FORESTS --- */}
      {showForests && data.forests.map((forest) => {
        const latLngs = geoJSONToLeaflet(forest.geoJson);
        if (latLngs.length === 0) return null;

        return (
          <Polygon
            key={forest.id}
            positions={latLngs}
            pathOptions={getForestStyle(forest.id)}
            eventHandlers={{
              click: (e) => {
                L.DomEvent.stopPropagation(e); // Verhindert Klick auf Map-Hintergrund
                selectFeature(forest.id, 'FOREST');
              },
              mouseover: () => setHovered(forest.id),
              mouseout: () => setHovered(null)
            }}
          >
            {/* Ocell-Style: Tooltip nur bei Hover, dezent */}
            <Tooltip sticky direction="top" opacity={0.8} className="custom-tooltip">
              <span className="font-bold">{forest.name}</span>
              <br />
              <span className="text-xs text-gray-500">{forest.areaHa?.toFixed(2)} ha</span>
            </Tooltip>
          </Polygon>
        );
      })}

      {/* --- LAYER: INFRASTRUKTUR (Wege) --- */}
      {showInfrastructure && data.forests.map(forest => (
        forest.paths?.map((path: any) => {
          const latLngs = geoJSONToLeaflet(path.geoJson);
          return (
            <Polyline
              key={path.id}
              positions={latLngs}
              pathOptions={{ 
                color: LAYER_REGISTRY.INFRASTRUCTURE.color, 
                weight: 4,
                opacity: 0.7 
              }}
            />
          );
        })
      ))}

      {/* --- LAYER: TASKS (Pins) --- */}
      {showTasks && data.tasks.map((task) => {
        if (!task.lat || !task.lng) return null;
        
        // Entscheide Icon Farbe basierend auf Prio
        const isUrgent = task.priority === 'URGENT' || task.priority === 'HIGH';
        const color = isUrgent ? '#ef4444' : '#3b82f6';

        // Custom HTML Icon für Performance & Look
        const icon = L.divIcon({
          className: 'bg-transparent',
          html: `<div style="
            background-color: ${color};
            width: 14px; height: 14px;
            border-radius: 50%;
            border: 2px solid white;
            box-shadow: 0 4px 6px rgba(0,0,0,0.3);
          "></div>`,
          iconSize: [14, 14],
          iconAnchor: [7, 7]
        });

        return (
          <Marker
            key={task.id}
            position={[task.lat, task.lng]}
            icon={icon}
            eventHandlers={{
              click: (e) => {
                L.DomEvent.stopPropagation(e);
                selectFeature(task.id, 'TASK');
              }
            }}
          >
             {/* Optional: Popup direkt, oder besser via Store in Sidebar anzeigen */}
          </Marker>
        );
      })}
    </>
  );
}
</file>

