'use client';

import { useMapStore } from '../stores/useMapStores';
import { X, Trees, CheckSquare, Info } from 'lucide-react';
import { useEffect, useState } from 'react';

export function MapDetailPanel() {
  const selectedId = useMapStore((s) => s.selectedFeatureId);
  const selectedType = useMapStore((s) => s.selectedFeatureType);
  const selectFeature = useMapStore((s) => s.selectFeature);
  
  const [isVisible, setIsVisible] = useState(false);

  // Animationseffekt: Wenn ID gesetzt ist, einblenden
  useEffect(() => {
    setIsVisible(!!selectedId);
  }, [selectedId]);

  if (!selectedId && !isVisible) return null;

  const handleClose = () => {
    setIsVisible(false);
    // Kurze Verzögerung für Animation, dann im Store leeren
    setTimeout(() => selectFeature(null, null), 300);
