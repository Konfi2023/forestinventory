<file path="keycloak-theme/forest-dark/login/resources/css/styles.css">
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap');

/* 1. KEYCLOAK RESET */
* { box-sizing: border-box; }
body {
    background-color: #000000 !important; 
    margin: 0 !important;
    padding: 0 !important;
    font-family: 'Inter', sans-serif !important;
    overflow: hidden !important;
}

/* Verstecke Standard Keycloak Elemente */
.login-pf-page-header, #kc-header, #kc-header-wrapper, #kc-content-wrapper .alert { display: none !important; }

/* 2. TOP NAVIGATION */
.np-top-nav {
    position: absolute; top: 40px; left: 40px; z-index: 10002;
    display: flex; align-items: center; gap: 30px;
}
.np-back-link {
    color: #9ca3af; text-decoration: none; font-size: 14px; font-weight: 600;
    display: flex; align-items: center; gap: 8px; transition: all 0.2s;
    background: rgba(255, 255, 255, 0.05); padding: 8px 16px;
    border-radius: 99px; border: 1px solid rgba(255, 255, 255, 0.1);
}
.np-back-link:hover {
    color: #ffffff; background: rgba(255, 255, 255, 0.1); border-color: rgba(255, 255, 255, 0.2);
}

/* 3. LAYOUT */
.np-auth-page {
    position: fixed !important; top: 0; left: 0; width: 100vw; height: 100vh;
    background-color: #000000; z-index: 9999;
    display: flex; align-items: center; justify-content: center; overflow-y: auto; color: #fff;
}
.np-auth-container {
    width: 95%; max-width: 1600px; height: 800px;
    display: flex; flex-direction: row; align-items: center; justify-content: center;
    gap: 150px; padding: 0 20px;
}

/* Linke Seite */
.np-auth-left { flex: 1; max-width: 460px; display: flex; flex-direction: column; justify-content: center; position: relative; z-index: 10000; }
.np-auth-heading { margin-bottom: 32px; }
.np-auth-signup-title { font-size: 36px; line-height: 1.1; font-weight: 700; color: #ffffff; margin: 0 0 10px 0; }
.np-auth-subtitle { font-size: 16px; color: #a1a1aa; margin: 0; }
.np-auth-form { display: flex; flex-direction: column; gap: 24px; }

/* ------------ INPUTS (Modern Dark Style) ------------ */
.np-input-group {
    display: flex; flex-direction: column; width: 100%; margin-bottom: 5px;
}
.np-input-label-pill-wrapper {
    position: static; margin-bottom: 8px; margin-left: 4px;
}
.np-input-label-pill {
    background: transparent; padding: 0; font-size: 13px; font-weight: 600;
    color: #a1a1aa; text-transform: uppercase; letter-spacing: 0.05em;
}
.np-input {
    width: 100%; height: 52px; border-radius: 12px; border: 1px solid #27272a;
    background-color: #111111 !important; color: #ffffff !important; padding: 0 16px;
    font-size: 16px; outline: none; box-sizing: border-box; transition: all 0.2s ease;
}
.np-input:hover { border-color: #3f3f46; }
.np-input:focus { border-color: #59FF85; background-color: #000000 !important; box-shadow: 0 0 0 1px #59FF85; }

/* Browser Autofill Fix */
input:-webkit-autofill, input:-webkit-autofill:hover, input:-webkit-autofill:focus, input:-webkit-autofill:active {
    -webkit-box-shadow: 0 0 0 30px #111111 inset !important;
    -webkit-text-fill-color: white !important; caret-color: white; border: 1px solid #333;
}

/* Button */
.np-primary-button {
    margin-top: 10px; width: 100%; height: 56px; border-radius: 99px; border: none;
    background: #59FF85; color: #000000; font-size: 16px; font-weight: 700;
    cursor: pointer; transition: transform 0.1s, box-shadow 0.2s;
}
.np-primary-button:hover { transform: translateY(-2px); box-shadow: 0 0 25px rgba(89, 255, 133, 0.4); }

/* Footer */
.np-auth-footer-text { text-align: center; font-size: 14px; color: #6b7280; margin-top: 30px; }
.np-link { color: #59FF85; text-decoration: none; margin-left: 4px; font-weight: 600; }
.np-link:hover { text-decoration: underline; }

/* Rechte Seite (Bild) */
.np-auth-right {
    flex: 1.6; height: 100%; position: relative; border-radius: 40px; overflow: hidden;
    background: #0f120f; display: flex; align-items: flex-end;
}
.np-image-bg {
    width: 100%; height: 100%; position: absolute; top: 0; left: 0; z-index: 1;
    background-size: cover; background-position: center; background-repeat: no-repeat;
    background-image: url('../img/deer.jpg');
    transition: transform 10s ease;
}
.np-auth-right:hover .np-image-bg { transform: scale(1.05); }
.np-image-overlay { position: absolute; inset: 0; z-index: 2; background: linear-gradient(to bottom, rgba(0,0,0,0) 0%, rgba(0,0,0,0.4) 50%, rgba(0,0,0,0.9) 100%); }
.np-image-content { position: relative; z-index: 3; padding: 60px; color: #ffffff; }
.np-quote-icon { font-size: 40px; color: #59FF85; line-height: 1; margin-bottom: 20px; }
.np-image-title { font-size: 32px; font-weight: 700; line-height: 1.2; margin-bottom: 12px; }
.np-image-text { font-size: 16px; line-height: 1.6; color: rgba(255, 255, 255, 0.9); max-width: 90%; }

/* Responsive */
@media (max-width: 1000px) {
    .np-auth-right { display: none; }
    .np-auth-container { width: 100%; padding: 40px 20px; gap: 0; }
    .np-top-nav { top: 20px; left: 20px; }
    .np-auth-left { width: 100%; max-width: 460px; }
}
</file>

