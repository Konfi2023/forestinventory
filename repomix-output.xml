          {selectedType === 'TASK' && (
            <div className="space-y-4">
              <div>
                <label className="text-xs text-gray-500 uppercase font-bold">Status</label>
                <select className="w-full mt-1 bg-black border border-white/20 rounded p-2 text-sm text-white">
                  <option>Offen</option>
