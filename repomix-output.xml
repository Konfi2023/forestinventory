          <X className="w-5 h-5" />
        </button>
      </div>

      {/* CONTENT (Platzhalter) */}
      <div className="p-6 flex-1 overflow-y-auto text-gray-300">
        <div className="space-y-6">
          
          {/* ID Anzeige (Debugging) */}
          <div className="bg-black/30 p-3 rounded-lg border border-white/5 font-mono text-xs text-gray-500 break-all">
            ID: {selectedId}
          </div>

          {/* Ocell-Style Metadaten */}
          {selectedType === 'FOREST' && (
            <>
              <div className="grid grid-cols-2 gap-4">
                <div className="bg-white/5 p-3 rounded-lg">
                  <div className="text-[10px] uppercase text-gray-500 font-bold">Fläche</div>
