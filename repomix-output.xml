<file path="src/keycloak-theme/forest-dark/login/resources/css/styles.css">
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap');

/* 1. KEYCLOAK RESET */
* { box-sizing: border-box; }
body {
    background-color: #000000 !important; 
    margin: 0 !important;
    padding: 0 !important;
    font-family: 'Inter', sans-serif !important;
    overflow: hidden !important;
}

/* Verstecke Standard Keycloak Elemente */
.login-pf-page-header, #kc-header, #kc-header-wrapper, #kc-content-wrapper .alert { display: none !important; }

/* 2. TOP NAVIGATION */
.np-top-nav {
    position: absolute; top: 40px; left: 40px; z-index: 10002;
    display: flex; align-items: center; gap: 30px;
}
.np-back-link {
    color: #9ca3af; text-decoration: none; font-size: 14px; font-weight: 600;
    display: flex; align-items: center; gap: 8px; transition: all 0.2s;
    background: rgba(255, 255, 255, 0.05); padding: 8px 16px;
    border-radius: 99px; border: 1px solid rgba(255, 255, 255, 0.1);
}
.np-back-link:hover {
    color: #ffffff; background: rgba(255, 255, 255, 0.1); border-color: rgba(255, 255, 255, 0.2);
}

/* 3. LAYOUT */
.np-auth-page {
    position: fixed !important; top: 0; left: 0; width: 100vw; height: 100vh;
    background-color: #000000; z-index: 9999;
    display: flex; align-items: center; justify-content: center; overflow-y: auto; color: #fff;
}
.np-auth-container {
    width: 95%; max-width: 1600px; height: 800px;
    display: flex; flex-direction: row; align-items: center; justify-content: center;
    gap: 150px; padding: 0 20px;
}

/* Linke Seite */
