  const user = await prisma.user.findUnique({
    where: { email: session.user.email },
    select: { isSystemAdmin: true },
  });

  if (!user || !user.isSystemAdmin) {
    // Entweder 404 oder Redirect zur Startseite
    redirect("/"); 
  }

  return session;
}
