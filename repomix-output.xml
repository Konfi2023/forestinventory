          <div className="grid grid-cols-2 gap-4">
            <div className="space-y-2">
              <Label htmlFor="name">Rufname (Dashboard)</Label>
              <Input id="name" name="name" defaultValue={organization.name} required />
            </div>
            <div className="space-y-2">
