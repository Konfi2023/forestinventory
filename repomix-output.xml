<file path="prisma/schema.prisma">
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- IAM & MANDANTEN ---

model Organization {
  id                 String       @id @default(uuid())
  name               String
  slug               String       @unique
  defaultLanguage    String       @default("de")
  stripeCustomerId   String?
  subscriptionStatus String?      @default("FREE")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  members            Membership[]
  roles              Role[]
  invites            Invite[]
  auditLogs          AuditLog[]
  forests            Forest[]
  // Globale Listen für CRM/Verkauf auf Org-Ebene
  timberSales        TimberSale[]
  legalName          String? // Offizieller Firmenname
  orgType            OrgType      @default(PRIVATE_OWNER)
  totalHectares      Float? // Betriebsgröße
  // Adresse & Rechnung
  billingEmail       String?
  vatId              String? // USt-IdNr.
  street             String?
  zip                String?
  city               String?
  country            String?      @default("Deutschland")
  Event              Event[]
}

model User {
  id                 String       @id @default(uuid())
  keycloakId         String       @unique
  email              String       @unique
  firstName          String?
  lastName           String?
  isSystemAdmin      Boolean      @default(false)
  companyName        String?
  vatId              String?
  street             String?
  zip                String?
  calendarToken String? @unique
  city               String?
  country            String?      @default("Deutschland")
  preferredLanguage  String       @default("de")
  onboardingComplete Boolean      @default(false)
  lastActiveOrgId    String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  memberships        Membership[]
  auditLogs          AuditLog[]
  invoices           Invoice[]
  accessibleForests  Forest[]     @relation("ForestAccess")
  

  // --- NEU: Zuweisungen & Tracking ---
  assignedTasks         Task[]         @relation("TaskAssignee")
  createdTasks          Task[]         @relation("TaskCreator")
  createdSchedules      TaskSchedule[] @relation("ScheduleCreator")
  createdEvents         Event[]
  timeEntries           TimeEntry[]
  taskComments          TaskComment[]
  watchedTasks          Task[]         @relation("TaskWatchers")
  receivedNotifications Notification[] @relation("NotifReceiver")
  sentNotifications     Notification[] @relation("NotifActor")
  TaskSchedule          TaskSchedule[]
}

model Membership {
  id             String       @id @default(uuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  roleId         String
  role           Role         @relation(fields: [roleId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

model Role {
  id             String       @id @default(uuid())
  name           String
  description    String?
  permissions    String[]
  isSystemRole   Boolean      @default(false)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members        Membership[]
  invites        Invite[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([name, organizationId])
}

model Invite {
  id             String       @id @default(uuid())
  email          String
  token          String       @unique
  expiresAt      DateTime
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  roleId         String
  role           Role         @relation(fields: [roleId], references: [id])
  inviterId      String?
  status         String       @default("PENDING")
  createdAt      DateTime     @default(now())
}

model Event {
  id          String  @id @default(uuid())
  title       String
  description String?

  start  DateTime
  end    DateTime?
  allDay Boolean   @default(false)

  // Farbe für den Kalender (optional, sonst Standard)
  color String? @default("#10b981") // Standard Grün

  // Verknüpfungen
  forestId String? // Optional: Termin gehört zu einem Wald
  forest   Forest? @relation(fields: [forestId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

