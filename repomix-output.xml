  { code: "RO", label: "Rumänien" },    { code: "SE", label: "Schweden" },
  { code: "FI", label: "Finnland" },    { code: "OTHER", label: "Sonstiges" },
];

interface Props {
  orgSlug: string;
  defaultActivityType: string;
  forests: { id: string; name: string }[];
