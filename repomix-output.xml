"use server";

import { prisma } from "@/lib/prisma";
import { revalidatePath } from "next/cache";
import { requireAuthContext } from "@/lib/rbac-middleware"; // Unsere neue Middleware
import { PERMISSIONS } from "@/lib/permissions";

// --- CREATE FOREST (Kompatibel mit Map Editor) ---
export async function createForest(data: {
  name: string;
  geoJson: any; // Wichtig für die Karte
  areaHa: number;
  keycloakId: string; // Wird vom Frontend übergeben
  description?: string;
  location?: string;
  grantedUserIds?: string[];
}) {
  try {
    // 1. Context & Berechtigung prüfen (ersetzt checkPermission)
    // Wir prüfen, ob der User zur Org gehört und Rechte hat
    const { organizationId, userId } = await requireAuthContext(data.keycloakId, PERMISSIONS.FOREST_EDIT);

    // 2. Wald erstellen
    const forest = await prisma.forest.create({
      data: {
        name: data.name,
        description: data.description,
        location: data.location,
        geoJson: data.geoJson, // Hier speichern wir die Zeichnung
        areaHa: data.areaHa,
        
        // Verknüpfung zur Organisation (WICHTIG!)
        organizationId: organizationId,
        
        // Falls du User direkt zuweisen willst (Legacy Support)
        grantedUsers: {
          connect: [{ id: userId }, ...(data.grantedUserIds?.map(id => ({ id })) || [])]
        }
      }
    });

    // Caches leeren
    revalidatePath("/dashboard/map");
    revalidatePath("/dashboard");
    
    return { success: true, forestId: forest.id };

  } catch (e: any) {
    console.error("Create Forest Error:", e);
    return { success: false, error: e.message };
  }
}

// --- UPDATE FOREST ---
export async function updateForest(data: {
  id: string;
  keycloakId: string;
  name: string;
  geoJson?: any;
  areaHa?: number;
  description?: string;
}) {
  try {
    const { organizationId } = await requireAuthContext(data.keycloakId, PERMISSIONS.FOREST_EDIT);

    // Prüfen, ob Wald zur Org gehört
    const existing = await prisma.forest.findFirst({
      where: { id: data.id, organizationId }
    });

    if (!existing) throw new Error("Wald nicht gefunden oder kein Zugriff");

    await prisma.forest.update({
      where: { id: data.id },
      data: {
        name: data.name,
        description: data.description,
        geoJson: data.geoJson,
        areaHa: data.areaHa
      }
    });

    revalidatePath("/dashboard/map");
    return { success: true };
  } catch (e: any) {
    return { success: false, error: e.message };
  }
}

// --- DELETE FOREST ---
export async function deleteForest(forestId: string, keycloakId: string) {
  try {
    const { organizationId } = await requireAuthContext(keycloakId, PERMISSIONS.FOREST_DELETE);

    const existing = await prisma.forest.findFirst({
      where: { id: forestId, organizationId }
    });

    if (!existing) throw new Error("Nicht gefunden");

    await prisma.forest.delete({ where: { id: forestId } });

    revalidatePath("/dashboard/map");
    return { success: true };
  } catch (e: any) {
    return { success: false, error: e.message };
  }
}
