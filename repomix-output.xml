    where: { id: taskId },
    data: {
      scheduledDate: null,
      scheduledEndDate: null
    }
  });

  revalidatePath(`/dashboard/org/${orgSlug}/calendar`);
  revalidatePath(`/dashboard/org/${orgSlug}/tasks`);
  return { success: true };
}
