'use server';

import { prisma } from '@/lib/prisma';
import { getActiveOrgId } from '@/app/actions/org-actions'; // Deine bestehende Action
import { requireAuthContext } from '@/lib/rbac-middleware';
import { PERMISSIONS } from '@/lib/permissions';

export async function getMapData(keycloakId: string) {
  try {
    // 1. Sicherheit & Kontext (Org ID)
    const { organizationId } = await requireAuthContext(keycloakId, PERMISSIONS.FOREST_VIEW);

    // 2. Wälder laden (Inklusive Infrastruktur für Layer)
    const forests = await prisma.forest.findMany({
      where: { organizationId },
      select: {
        id: true,
        name: true,
        geoJson: true,
        areaHa: true,
        // Lade nur das Nötigste für die Karte, keine Blobs/Bilder
        paths: {
          select: { id: true, type: true, geoJson: true }
        },
        pois: {
          select: { id: true, type: true, lat: true, lng: true, name: true }
        }
      }
    });

    // 3. Tasks laden (Nur die mit Geo-Koordinaten)
    // Wir laden ALLE Tasks der Organisation, die Koordinaten haben
    const tasks = await prisma.task.findMany({
      where: {
        forest: { organizationId }, // Tasks via Forest->Org Verknüpfung
        lat: { not: null },
        lng: { not: null },
        status: { not: 'DONE' } // Nur offene Aufgaben anzeigen
      },
      select: {
        id: true,
        title: true,
        status: true,
        priority: true,
        lat: true,
        lng: true,
        forestId: true
      }
    });

    return { forests, tasks };

  } catch (error) {
    console.error("Map Data Fetch Error:", error);
    return { forests: [], tasks: [] }; // Fail safe
  }
}
</file>

<file path="app/dashboard/map/MapPageClient.tsx">
'use client';

import { useEffect, useState } from 'react';
import { useSession } from "next-auth/react";
import { getMapData } from './actions';
import { Loader2 } from 'lucide-react';
import dynamic from 'next/dynamic';

// Importieren des neuen Panels
import { MapDetailPanel } from '@/components/map/overlays/MapDetailPanel'; 

const MapViewer = dynamic(
  () => import('@/components/map/viewer/MapViewer'),
  {
    ssr: false,
    loading: () => (
      <div className="w-full h-full bg-[#050505] flex items-center justify-center text-gray-500">
        <Loader2 className="animate-spin w-8 h-8 text-green-500 mr-2" />
        <span className="font-mono text-sm">Karte wird initialisiert...</span>
      </div>
    )
  }
);

export default function MapPageClient() {
  const { data: session, status } = useSession();
  const [data, setData] = useState<{forests: any[], tasks: any[]} | null>(null);

  useEffect(() => {
    if (status === "authenticated" && session?.user?.id) {
      getMapData(session.user.id).then(setData).catch(console.error);
    }
  }, [status, session?.user?.id]);

  if (status === "loading" || (status === "authenticated" && !data)) {
    return (
      <div className="w-full h-full flex items-center justify-center text-gray-500 bg-[#050505]">
        <Loader2 className="animate-spin w-8 h-8 text-green-500" />
      </div>
    );
  }

  if (status === "unauthenticated") return <div>Access Denied</div>;

  return (
    <div className="relative w-full h-full overflow-hidden">
      {/* 1. Die Karte (Hintergrund) */}
      <MapViewer forestData={data} />
      
      {/* 2. Das Detail Panel (Overlay) */}
      <MapDetailPanel />
    </div>
  );
}
</file>

