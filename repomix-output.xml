  // Mock-Daten Logik (Später laden wir hier echte Daten nach)
  const getHeaderIcon = () => {
    switch (selectedType) {
      case 'FOREST': return <Trees className="w-5 h-5 text-green-500" />;
      case 'TASK': return <CheckSquare className="w-5 h-5 text-red-500" />;
      default: return <Info className="w-5 h-5 text-blue-500" />;
    }
  };

  const getTitle = () => {
    if (selectedType === 'FOREST') return "Waldfläche Details";
    if (selectedType === 'TASK') return "Aufgabe bearbeiten";
    return "Objekt Details";
  };

  return (
    <div 
      className={`
        absolute top-4 bottom-4 right-4 w-96 
        bg-[#151515]/95 backdrop-blur-xl border border-white/10 
        rounded-xl shadow-2xl z-[1000] overflow-hidden flex flex-col
