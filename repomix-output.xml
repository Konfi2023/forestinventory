}

// ─── Edit Dialog ──────────────────────────────────────────────────────────────

function EditLogPileDialog({ pile, orgSlug, onClose }: { pile: any; orgSlug: string; onClose: () => void }) {
  const [saving, setSaving] = useState(false);
  const [name,        setName]        = useState(pile.name ?? "");
