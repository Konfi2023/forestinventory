const EU_COUNTRIES = [
  { code: "DE", label: "Deutschland" }, { code: "AT", label: "Österreich" },
  { code: "CH", label: "Schweiz" },     { code: "FR", label: "Frankreich" },
  { code: "PL", label: "Polen" },       { code: "CZ", label: "Tschechien" },
