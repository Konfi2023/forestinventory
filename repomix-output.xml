  pricePerUnit?: number;
  eudrReference?: string | null;
}) {
  const session = await getServerSession(authOptions);
  if (!session?.user) throw new Error("Nicht eingeloggt");

  await prisma.timberSale.update({ where: { id }, data });
  revalidate(orgSlug);
  return { success: true };
}

