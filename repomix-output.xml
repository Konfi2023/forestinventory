<file path="components/map/viewer/MapViewer.tsx">
'use client';

import { useEffect } from 'react';
import { MapContainer, TileLayer, ZoomControl, useMap } from 'react-leaflet';
import L from 'leaflet';
import 'leaflet/dist/leaflet.css';
import dynamic from 'next/dynamic';

// Store & Registry
// Achte auf den Plural "stores/useMapStores", wie in deiner Ordnerstruktur
import { useMapStore } from '../stores/useMapStores';

// Komponenten & Overlays
import { GeoDataHandler } from './GeoDataHandler';
import { LayerControl } from '../overlays/LayerControl';
import { MapToolbar } from '../overlays/MapToolbar';

// Editor lazy laden (verhindert Laden von leaflet-draw, wenn man nur guckt)
const MapGeometryEditor = dynamic(
  () => import('../editor/MapGeometryEditor'),
  { ssr: false }
);

// --- 1. Fix für fehlende Leaflet Icons ---
// Leaflet hat standardmäßig Probleme mit Icon-Pfaden in Webpack/Next.js
const fixLeafletIcons = () => {
  // @ts-ignore
  delete L.Icon.Default.prototype._getIconUrl;
  L.Icon.Default.mergeOptions({
    iconRetinaUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.7.1/images/marker-icon-2x.png',
    iconUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.7.1/images/marker-icon.png',
    shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.7.1/images/marker-shadow.png',
  });
};

// --- 2. Map Controller (Logik-Brücke) ---
// Diese Komponente rendert nichts, sondern verbindet die Leaflet-Instanz mit unserem Zustand-Store
function MapController() {
  const map = useMap();
  const setMapReady = useMapStore((s) => s.setMapReady);

  useEffect(() => {
    fixLeafletIcons();
    setMapReady(true);
    
    // Wir speichern die "flyTo" Funktion im globalen Store.
    // So können wir von überall (z.B. aus der Sidebar) die Karte steuern.
    useMapStore.setState({ 
      flyTo: (coords, zoom) => map.flyTo(coords, zoom || 16, { duration: 1.5 }) 
    });

    return () => setMapReady(false);
  }, [map, setMapReady]);

  return null;
}

// --- 3. Haupt-Komponente ---
interface MapViewerProps {
  forestData: any; // Daten kommen von der Server Action
}

export default function MapViewer({ forestData }: MapViewerProps) {
  // Zugriff auf den Interaktions-Modus (VIEW vs DRAW)
  const interactionMode = useMapStore((s) => s.interactionMode);

  return (
    <div className="relative w-full h-full bg-[#050505] overflow-hidden">
      
      {/* --- OVERLAYS (Liegen über der Karte) --- */}
      
      {/* Toolbar: Neuer Wald erstellen */}
      <MapToolbar />

      {/* Layer Control: Ebenen umschalten */}
      <div className="absolute top-4 right-4 z-[1000]">
        <LayerControl />
      </div>

      {/* --- KARTE --- */}
      <MapContainer
        center={[51.1657, 10.4515]} // Default: Mitte Deutschland
        zoom={6}
        className="w-full h-full z-0"
        zoomControl={false} // Wir nutzen eigene Position für Zoom
        minZoom={4}
        maxZoom={20}
      >
        {/* Basiskarte: Dark Matter (Ideal für Datenvisualisierung) */}
        <TileLayer
          url="https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png"
          attribution='&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a> &copy; <a href="https://carto.com/attributions">CARTO</a>'
        />
        
        {/* Logik laden */}
        <MapController />
        
        {/* Zoom Controls unten rechts */}
        <ZoomControl position="bottomright" />

        {/* --- DATEN RENDERER --- */}
        {/* Zeigt Polygone, Pins und Wege basierend auf Filtern an */}
        <GeoDataHandler data={forestData} />

        {/* --- EDITOR (Konditional) --- */}
        {/* Wird nur geladen und angezeigt, wenn der User "Neuer Wald" klickt */}
        {interactionMode === 'DRAW_FOREST' && (
           <MapGeometryEditor />
        )}

      </MapContainer>
    </div>
  );
}
</file>

