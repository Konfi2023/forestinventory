          <div className="font-bold text-xl tracking-tight flex items-center gap-2">
            <ShieldAlert className="text-red-500" />
            <span>Admin<span className="text-red-500">Panel</span></span>
          </div>
        </div>

        <nav className="flex-1 p-4 space-y-2">
