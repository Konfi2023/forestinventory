<file path="components/map/editor/MapGeometryEditor.tsx">
'use client';

import { useEffect, useRef } from 'react';
import { useMap } from 'react-leaflet';
import { useMapStore } from '../stores/useMapStores';
import { createForest } from '@/actions/forest';
import { useSession } from 'next-auth/react';
import { toast } from 'sonner';
import L from 'leaflet';

// Wir brauchen leaflet-draw für die Funktionalität und CSS
import 'leaflet-draw';
import 'leaflet-draw/dist/leaflet.draw.css';

export default function MapGeometryEditor() {
  const map = useMap(); // Zugriff auf die Leaflet-Instanz
  const { data: session } = useSession();
  const setMode = useMapStore(s => s.setInteractionMode);
  
  // Ref, um den Drawer zu speichern, damit wir ihn sauber beenden können
  const drawerRef = useRef<L.Draw.Polygon | null>(null);

  useEffect(() => {
    if (!map) return;

    // 1. Das Polygon-Werkzeug konfigurieren
    // @ts-ignore - Leaflet Draw Typen sind manchmal zickig mit TS
    const drawer = new L.Draw.Polygon(map, {
      allowIntersection: false,
      guidelineDistance: 10,
      showArea: true,
      drawError: {
        color: '#e1e100',
        message: '<strong>Fehler:</strong> Kanten dürfen sich nicht überschneiden!'
      },
      shapeOptions: {
        color: '#10b981', // Emerald-500 (Passend zu deinem Button)
        weight: 3,
        opacity: 1,
        fillOpacity: 0.2
      }
    });

    drawerRef.current = drawer;

    // 2. SOFORT aktivieren (Der User muss nicht erst ein Icon klicken)
    drawer.enable();

    // 3. Event Handler: Wenn das Polygon fertig gezeichnet ist
    const onCreated = async (e: any) => {
      const layer = e.layer;
      const geoJson = layer.toGeoJSON();

      // Sofort deaktivieren, damit man nicht aus Versehen weiter malt
      drawer.disable();

      // Simple Namensabfrage (kann später durch ein schickes Modal ersetzt werden)
      // Eine kleine Verzögerung hilft, damit Leaflet sich "beruhigen" kann
      setTimeout(async () => {
        const forestName = prompt("Wie soll dieser Wald heißen?");
        
        if (!forestName) {
          // Abbruch: Wir entfernen die Zeichnung und gehen zurück
          map.removeLayer(layer);
          setMode('VIEW');
          return;
        }

        try {
          // Berechnung der Fläche in Hektar (sehr grob via Leaflet Helper oder Turf)
          // Hier nutzen wir eine einfache Annäherung oder lassen das Backend rechnen.
          // Fürs Erste senden wir 0, das Backend oder ein Turf-Helper macht den Rest.
          
          const result = await createForest({
            name: forestName,
            geoJson: geoJson,
            areaHa: 0, 
            keycloakId: session?.user?.id as string,
          });

          if (result.success) {
            toast.success("Wald angelegt!");
            // Layer zur Karte hinzufügen (visuelles Feedback)
            map.addLayer(layer);
            
            // Reload ist die sicherste Variante, um die neuen Daten sauber via Server zu holen
            window.location.reload();
          } else {
            toast.error("Fehler: " + result.error);
            map.removeLayer(layer);
          }
        } catch (err) {
          console.error(err);
          toast.error("Speichern fehlgeschlagen.");
          map.removeLayer(layer);
        } finally {
          setMode('VIEW');
        }
      }, 100);
    };

    // Event Listener registrieren
    map.on(L.Draw.Event.CREATED, onCreated);

    // 4. Cleanup: Wenn der User "Abbrechen" klickt oder die Komponente unmountet
    return () => {
      drawer.disable();
      map.off(L.Draw.Event.CREATED, onCreated);
    };
  }, [map, session, setMode]);

  return null; // Diese Komponente rendert kein sichtbares HTML, sie steuert nur die Karte
}
</file>

